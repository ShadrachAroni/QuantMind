{
  "name": "quantmind-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "postinstall": "node -e \"const fs = require('fs'); const path = require('path'); const codegenPath = path.join('node_modules', 'ajv', 'dist', 'compile', 'codegen.js'); if (fs.existsSync(path.dirname(codegenPath)) && !fs.existsSync(codegenPath)) { fs.writeFileSync(codegenPath, 'module.exports = require(\\\"./codegen/index.js\\\");'); console.log('✅ Created ajv codegen shim'); }\""
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "chalk": "^4.1.2",
    "fs-extra": "^11.1.1",
    "glob": "^11.0.0",
    "expo-module-scripts": "^5.0.8",
    "resolve-from": "^5.0.0",
    "turbo": "latest"
  },
  "overrides": {
    "fast-xml-parser": "^5.0.0",
    "glob": "^11.0.0",
    "minimatch": "^9.0.7",
    "d3-color": "^3.1.0",
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "next": "^15.1.0",
    "picomatch": "^4.0.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "typescript": "~5.9.2"
  }
}
