{
    "expo": {
        "name": "Quantmind",
        "slug": "quantmind",
        "version": "1.0.0",
        "orientation": "default",
        "icon": "./assets/icon.png",
        "scheme": "quantmind",
        "userInterfaceStyle": "dark",
        "backgroundColor": "#05070a",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "cover",
            "backgroundColor": "#05070a",
            "dark": {
                "image": "./assets/splash.png",
                "backgroundColor": "#05070a"
            }
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.quantmind.app",
            "userInterfaceStyle": "dark",
            "splash": {
                "image": "./assets/splash.png",
                "resizeMode": "cover",
                "backgroundColor": "#05070a",
                "dark": {
                    "image": "./assets/splash.png",
                    "backgroundColor": "#05070a"
                }
            },
            "infoPlist": {
                "NSCameraUsageDescription": "Quantmind needs camera access for document scanning",
                "NSFaceIDUsageDescription": "Quantmind uses Face ID for secure authentication"
            }
        },
        "android": {
            "supportsTablet": true,
            "userInterfaceStyle": "dark",
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#05070a"
            },
            "splash": {
                "image": "./assets/splash.png",
                "resizeMode": "cover",
                "backgroundColor": "#05070a",
                "dark": {
                    "image": "./assets/splash.png",
                    "backgroundColor": "#05070a"
                }
            },
            "package": "com.quantmind.app",
            "permissions": [
                "android.permission.CAMERA",
                "android.permission.USE_BIOMETRIC",
                "android.permission.USE_FINGERPRINT"
            ]
        },
        "web": {
            "bundler": "metro",
            "output": "single",
            "favicon": "./assets/favicon.png"
        },
        "plugins": [
            "expo-secure-store",
            "expo-notifications",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/splash.png",
                    "backgroundColor": "#05070a",
                    "dark": {
                        "image": "./assets/splash.png",
                        "backgroundColor": "#05070a"
                    }
                }
            ],
            "./plugins/withWidgets",
            [
                "expo-updates",
                {
                    "username": "quantmind"
                }
            ]
        ],
        "experiments": {
            "autolinkingModuleResolution": true
        },
        "extra": {
            "eas": {
                "projectId": "quantmind-app"
            }
        }
    }
}