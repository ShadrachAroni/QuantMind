{
    "expo": {
        "name": "Quantmind",
        "slug": "quantmind",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "scheme": "quantmind",
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#0A0E17"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.quantmind.app",
            "infoPlist": {
                "NSCameraUsageDescription": "Quantmind needs camera access for document scanning",
                "NSFaceIDUsageDescription": "Quantmind uses Face ID for secure authentication"
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#0A0E17"
            },
            "package": "com.quantmind.app",
            "permissions": [
                "android.permission.CAMERA",
                "android.permission.USE_BIOMETRIC",
                "android.permission.USE_FINGERPRINT"
            ]
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./assets/favicon.png"
        },
        "plugins": [
            "expo-router",
            "expo-secure-store",
            "expo-notifications",
            [
                "expo-updates",
                {
                    "username": "quantmind"
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        },
        "extra": {
            "eas": {
                "projectId": "quantmind-app"
            }
        }
    }
}