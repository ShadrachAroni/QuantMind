{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_APP_URL",
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "SUPABASE_JWT_SECRET",
        "SUPABASE_PUBLISHABLE_KEY",
        "SUPABASE_SECRET_KEY",
        "SITE_URL",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "GEMINI_API_KEY",
        "ANTHROPIC_API_KEY",
        "UPSTASH_REDIS_URL",
        "UPSTASH_REDIS_TOKEN",
        "TWELVE_DATA_API_KEY",
        "ALPHA_VANTAGE_API_KEY",
        "FINNHUB_API_KEY",
        "CRON_SECRET",
        "PAYSTACK_SECRET_KEY",
        "PAYSTACK_PLAN_STUDENT",
        "PAYSTACK_PLAN_STUDENT_YEARLY",
        "PAYSTACK_PLAN_PLUS",
        "PAYSTACK_PLAN_PLUS_YEARLY",
        "PAYSTACK_PLAN_PRO",
        "PAYSTACK_PLAN_PRO_YEARLY",
        "POSTGRES_URL",
        "POSTGRES_PRISMA_URL",
        "POSTGRES_URL_NON_POOLING",
        "POSTGRES_USER",
        "POSTGRES_HOST",
        "POSTGRES_PASSWORD",
        "POSTGRES_DATABASE",
        "SIMULATION_SECRET_KEY",
        "SIMULATION_SERVICE_URL",
        "REVENUECAT_WEBHOOK_SECRET"
      ]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": true
    }
  }
}
