# Supabase Edge Functions - Configuration
# Set these using: supabase secrets set KEY=VALUE

# Core Supabase
SUPABASE_URL=your-project-url.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Assistant (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=your-anthropic-key

# Notifications
RESEND_API_KEY=your-resend-key

# Rate Limiting & Jobs
UPSTASH_REDIS_URL=your-redis-url
UPSTASH_REDIS_TOKEN=your-redis-token

# Market Data Providers (Calibration)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
TWELVE_DATA_API_KEY=your-twelve-data-key
FINNHUB_API_KEY=your-finnhub-key

# Subscriptions
REVENUECAT_WEBHOOK_SECRET=your-webhook-secret
PAYSTACK_SECRET_KEY=your-paystack-secret
PAYSTACK_PLAN_PLUS=PLN_plus_123
PAYSTACK_PLAN_PRO=PLN_pro_456
PAYSTACK_PLAN_STUDENT=PLN_student_789
PAYSTACK_CALLBACK_URL=https://Quantmind.co.ke/api/paystack/callback

# Internal Security
SIMULATION_SECRET_KEY=your-internal-secret
SIMULATION_SERVICE_URL=https://your-simulation-worker.com
