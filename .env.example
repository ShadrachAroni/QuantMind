# QuantMind Root Environment Variables Template
# Copy this to .env and fill in the values. 
# DO NOT EXPOSE API KEYS IN THIS FILE.

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic AI
ANTHROPIC_API_KEY=your-anthropic-key

# Upstash Redis
UPSTASH_REDIS_URL=your-redis-url
UPSTASH_REDIS_TOKEN=your-redis-token

# Resend (Email)
RESEND_API_KEY=your-resend-key
RESEND_FROM_EMAIL=verify@yourdomain.com

# Twelve Data
TWELVE_DATA_API_KEY=your-twelve-data-key

# Alpha Vantage
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Finnhub
FINNHUB_API_KEY=your-finnhub-key

# RevenueCat
REVENUECAT_WEBHOOK_SECRET=your-webhook-secret

# Simulation Service Secret
SIMULATION_SECRET_KEY=your-internal-secret

# --- OmniWealth Integrations ---
# MojoAuth (Passwordless Auth)
NEXT_PUBLIC_MOJOAUTH_API_KEY=your-mojoauth-public-key

# Warrant (Permissions/RBAC)
# Note: Warrant is implemented locally as a Relationship-Based Access Control (ReBAC) model.
# No external API keys are required for the standard implementation.

# Market Data (Stocks & Crypto)
MARKETSTACK_API_KEY=your-marketstack-key
FINAGE_API_KEY=your-finage-key

# FX Engine (Exchangerate.host)
EXCHANGERATE_API_KEY=your-exchangerate-key
